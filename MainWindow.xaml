<Window x:Class="ContextMenuManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ContextMenuManager"
        mc:Ignorable="d"
        Title="Sağ Tık Yöneticisi" 
        Height="780" Width="1020" 
        MinHeight="650" MinWidth="850" 
        WindowStartupLocation="CenterScreen" 
        Background="#F8FAFC" 
        FontSize="14" 
        FontFamily="Segoe UI, Roboto, Helvetica"
        Icon="Assets/app_icon.png">
    
    <Window.Resources>
        <!-- Form Label Style -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- Primary Button Style -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#334155"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1E293B"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0F172A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#94A3B8"/>
                                <Setter Property="Foreground" Value="#CBD5E1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary Button Style -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F1F5F9"/>
                                <Setter Property="BorderBrush" Value="#94A3B8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#E2E8F0"/>
                                <Setter Property="BorderBrush" Value="#64748B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Danger Button Style -->
        <Style x:Key="DangerButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FEE2E2"/>
            <Setter Property="Foreground" Value="#991B1B"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FCA5A5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#EF4444"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern TextBox Style -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Validation.ErrorTemplate" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" CornerRadius="6" SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="BorderBrush" TargetName="border" Value="#94A3B8"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter Property="BorderBrush" TargetName="border" Value="#64748B"/>
                                <Setter Property="BorderThickness" TargetName="border" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern ComboBox Style -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Modern CheckBox Style -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>

        <!-- Modern TabControl Style -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0,16,0,0"/>
        </Style>

        <!-- Modern TabItem Style -->
        <Style TargetType="TabItem">
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{TemplateBinding Content}" FontSize="15" FontWeight="SemiBold"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#0F172A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#334155"/>
                                <Setter Property="BorderBrush" Value="#334155"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern DataGrid Style -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F8FAFC"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="RowHeight" Value="38"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- DataGrid Header Style -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="Height" Value="38"/>
        </Style>

        <!-- DataGrid Cell Style -->
        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                            <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E2E8F0"/>
                    <Setter Property="Foreground" Value="#0F172A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style TargetType="DataGridRow">
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#F1F5F9"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E2E8F0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0" Source="Assets/app_icon.png" Width="48" Height="48" Margin="0,0,16,0" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="Sağ Tık Yöneticisi" FontSize="26" FontWeight="Bold" Foreground="#0F172A"/>
                <TextBlock Text="Klasör ve uygulama kısayolları ekleyin, gruplandırın ve Windows 11 sağ tık menüsünü düzenleyin." FontSize="14" Foreground="#64748B" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>
        
        <!-- Main Body Layout -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Left Side: Add Shortcut Form (Scrollable) -->
            <Border Grid.Column="0" Background="White" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Padding="20" Margin="0,0,20,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,4,0">
                        <StackPanel>
                            <TextBlock x:Name="FormTitleLabel" Text="Yeni Kısayol Ekle" FontSize="16" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,16"/>
                            
                            <!-- Shortcut Type -->
                            <TextBlock Text="Kısayol Türü" Style="{StaticResource LabelStyle}"/>
                            <ComboBox x:Name="TypeCombo" Margin="0,0,0,16" SelectedIndex="0" SelectionChanged="TypeCombo_SelectionChanged">
                                <ComboBoxItem Content="Klasör"/>
                                <ComboBoxItem Content="Dosya / Program"/>
                            </ComboBox>
                            
                            <!-- Target Type (Background, Directory, AllFiles, FileExtension) -->
                            <TextBlock Text="Hedef Alan (Nerede Görünsün?)" Style="{StaticResource LabelStyle}"/>
                            <ComboBox x:Name="TargetCombo" Margin="0,0,0,16" SelectedIndex="0" SelectionChanged="TargetCombo_SelectionChanged">
                                <ComboBoxItem Content="Boş Alan (Desktop veya Klasör İçi)"/>
                                <ComboBoxItem Content="Klasörün Kendisi"/>
                                <ComboBoxItem Content="Tüm Dosyalar (Herhangi bir dosya)"/>
                                <ComboBoxItem Content="Belirli Dosya Uzantısı"/>
                            </ComboBox>

                            <!-- Specific Extension Panel -->
                            <StackPanel x:Name="ExtensionPanel" Visibility="Collapsed" Margin="0,0,0,16">
                                <TextBlock Text="Dosya Uzantısı (örneğin: .txt)" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="ExtensionTxt" Height="36" VerticalContentAlignment="Center" Text=".txt"/>
                            </StackPanel>
                            
                            <!-- Menu Group -->
                            <TextBlock Text="Menü Grubu (Submenu)" Style="{StaticResource LabelStyle}"/>
                            <ComboBox x:Name="GroupCombo" IsEditable="True" Margin="0,0,0,16" Text="Ana Menü"/>
                            
                            <!-- Display Name -->
                            <TextBlock Text="Menüde Görünecek Ad" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="NameTxt" Margin="0,0,0,16" Height="36" VerticalContentAlignment="Center"/>
                            
                            <!-- Position Selection -->
                            <TextBlock Text="Menü Konumu (Sıralama)" Style="{StaticResource LabelStyle}"/>
                            <ComboBox x:Name="PositionCombo" Margin="0,0,0,16" SelectedIndex="0">
                                <ComboBoxItem Content="Varsayılan (Alfabetik)"/>
                                <ComboBoxItem Content="En Üstte (Top)"/>
                                <ComboBoxItem Content="En Altta (Bottom)"/>
                            </ComboBox>
                            
                            <!-- Target Path -->
                            <TextBlock x:Name="PathLabel" Text="Hedef Klasör Yolu" Style="{StaticResource LabelStyle}"/>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="PathTxt" Grid.Column="0" Height="36" VerticalContentAlignment="Center" Margin="0,0,8,0"/>
                                <Button x:Name="BrowseBtn" Grid.Column="1" Content="Gözat..." Width="80" Style="{StaticResource SecondaryButtonStyle}" Click="BrowseBtn_Click"/>
                            </Grid>
                            
                            <!-- Custom Icon Path -->
                            <TextBlock Text="Özel İkon Yolu (İsteğe Bağlı)" Style="{StaticResource LabelStyle}"/>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="IconTxt" Grid.Column="0" Height="36" VerticalContentAlignment="Center" Margin="0,0,8,0"/>
                                <Button x:Name="IconBrowseBtn" Grid.Column="1" Content="Seç..." Width="80" Style="{StaticResource SecondaryButtonStyle}" Click="IconBrowseBtn_Click"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                    
                    <!-- Submit Buttons -->
                    <Grid Grid.Row="1" Margin="0,10,0,0">
                        <Button x:Name="AddBtn" Content="Kısayolu Menüye Ekle" Height="40" Style="{StaticResource PrimaryButtonStyle}" Click="AddBtn_Click"/>
                        
                        <Grid x:Name="EditBtnGrid" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="SaveEditBtn" Grid.Column="0" Content="Değişiklikleri Kaydet" Height="40" Margin="0,0,6,0" Style="{StaticResource PrimaryButtonStyle}" Click="SaveEditBtn_Click"/>
                            <Button x:Name="CancelEditBtn" Grid.Column="1" Content="Vazgeç" Height="40" Margin="6,0,0,0" Style="{StaticResource SecondaryButtonStyle}" Click="CancelEditBtn_Click"/>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
            
            <!-- Right Side: Settings & Tabs -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- System Settings Card -->
                <Border Grid.Row="0" Background="White" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Padding="18" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Sistem Ayarları" FontSize="16" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,12"/>
                        <CheckBox x:Name="ClassicMenuChk" Content="Windows 11 Klasik Sağ Tık Menüsünü Etkinleştir (Explorer yeniden başlatılır)" Margin="0,0,0,12" Click="ClassicMenuChk_Click"/>
                        <CheckBox x:Name="PowerShellChk" Content="PowerShell Penceresini Burada Aç seçeneğini sabitle (Shift tuşuna basmak gerekmez)" Click="PowerShellChk_Click"/>
                    </StackPanel>
                </Border>
                
                <!-- TabControl Card -->
                <Border Grid.Row="1" Background="White" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Padding="20">
                    <TabControl>
                        
                        <!-- TAB 1: SHORTCUTS LIST -->
                        <TabItem Header="Eklenen Kısayollar">
                            <Grid Margin="0,10,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <!-- DataGrid showing shortcuts -->
                                <DataGrid x:Name="ShortcutsGrid" Grid.Row="0" AutoGenerateColumns="False" MouseDoubleClick="ShortcutsGrid_MouseDoubleClick">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Hedef Alan" Binding="{Binding TargetDisplay}" Width="110"/>
                                        <DataGridTextColumn Header="Grup (Menü)" Binding="{Binding Group}" Width="130"/>
                                        <DataGridTextColumn Header="Görünecek Ad" Binding="{Binding Name}" Width="160"/>
                                        <DataGridTextColumn Header="Sıralama" Binding="{Binding Position}" Width="90"/>
                                        <DataGridTextColumn Header="Hedef Yol" Binding="{Binding Path}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                                
                                <!-- List Buttons -->
                                <Grid Grid.Row="1" Margin="0,16,0,0">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                        <Button x:Name="EditBtn" Content="Seçileni Düzenle" Width="150" Height="38" Margin="0,0,10,0" Style="{StaticResource SecondaryButtonStyle}" Click="EditBtn_Click"/>
                                        <Button x:Name="DeleteBtn" Content="Seçilen Kısayolu Sil" Width="170" Height="38" Style="{StaticResource DangerButtonStyle}" Click="DeleteBtn_Click"/>
                                    </StackPanel>
                                    <Button x:Name="RefreshBtn" HorizontalAlignment="Right" Content="Listeyi Yenile" Width="130" Height="38" Style="{StaticResource SecondaryButtonStyle}" Click="RefreshBtn_Click"/>
                                </Grid>
                            </Grid>
                        </TabItem>
                        
                        <!-- TAB 2: QUICK PRESETS -->
                        <TabItem Header="Hazır Şablonlar (Hızlı Eylemler)">
                            <ScrollViewer Margin="0,10,0,0" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <!-- Preset 1: Restart Explorer -->
                                    <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Padding="0,0,0,16" Margin="0,0,0,16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Gezgini Yeniden Başlat" FontSize="15" FontWeight="Bold" Foreground="#334155"/>
                                                <TextBlock Text="Windows arayüzünü (explorer.exe) sonlandırıp yeniden başlatır. Donma ve takılmaları düzeltir." FontSize="13" Foreground="#64748B" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                                <TextBlock Text="Konum: Boş Alan (Masaüstü)" FontSize="12" Foreground="#94A3B8" Margin="0,6,0,0" FontWeight="SemiBold"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="Menüye Ekle" Width="120" Height="36" Style="{StaticResource SecondaryButtonStyle}" VerticalAlignment="Center" Click="PresetExplorer_Click"/>
                                        </Grid>
                                    </Border>

                                    <!-- Preset 2: Open Admin CMD Here -->
                                    <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Padding="0,0,0,16" Margin="0,0,0,16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Yönetici Komut İstemi (CMD) Burada Aç" FontSize="15" FontWeight="Bold" Foreground="#334155"/>
                                                <TextBlock Text="Sağ tıkladığınız konumda doğrudan Yönetici olarak çalıştırılmış CMD penceresi başlatır." FontSize="13" Foreground="#64748B" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                                <TextBlock Text="Konum: Boş Alan ve Klasörün Kendisi (İkisine birden eklenir)" FontSize="12" Foreground="#94A3B8" Margin="0,6,0,0" FontWeight="SemiBold"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="Menüye Ekle" Width="120" Height="36" Style="{StaticResource SecondaryButtonStyle}" VerticalAlignment="Center" Click="PresetAdminCmd_Click"/>
                                        </Grid>
                                    </Border>

                                    <!-- Preset 3: Temp Cleaner -->
                                    <Border Padding="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Geçici Dosyaları Temizle (Temp Cleaner)" FontSize="15" FontWeight="Bold" Foreground="#334155"/>
                                                <TextBlock Text="Bilgisayarınızdaki geçici Windows Temp dosyalarını arka planda PowerShell ile hızlıca siler." FontSize="13" Foreground="#64748B" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                                <TextBlock Text="Konum: Boş Alan (Masaüstü)" FontSize="12" Foreground="#94A3B8" Margin="0,6,0,0" FontWeight="SemiBold"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="Menüye Ekle" Width="120" Height="36" Style="{StaticResource SecondaryButtonStyle}" VerticalAlignment="Center" Click="PresetTempCleaner_Click"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                        
                        <!-- TAB 3: MENU CLEANER -->
                        <TabItem Header="Menü Temizleme (Temizlik Aracı)">
                            <Grid Margin="0,10,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <DataGrid x:Name="ShellExtensionsGrid" Grid.Row="0" AutoGenerateColumns="False">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Uygulama / Öğe Adı" Binding="{Binding KeyName}" Width="200"/>
                                        <DataGridTextColumn Header="Hedef Alan" Binding="{Binding TargetDisplay}" Width="150"/>
                                        <DataGridCheckBoxColumn Header="Engelli (Devre Dışı)" Binding="{Binding IsBlocked}" Width="140" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="GUID / CLSID" Binding="{Binding Clsid}" Width="280"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                                
                                <Grid Grid.Row="1" Margin="0,16,0,0">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                        <Button x:Name="ToggleBlockedBtn" Content="Devre Dışı Bırak / Etkinleştir" Width="220" Height="38" Style="{StaticResource PrimaryButtonStyle}" Click="ToggleBlockedBtn_Click"/>
                                    </StackPanel>
                                    <Button x:Name="RefreshExtensionsBtn" HorizontalAlignment="Right" Content="Listeyi Yenile" Width="130" Height="38" Style="{StaticResource SecondaryButtonStyle}" Click="RefreshExtensionsBtn_Click"/>
                                </Grid>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
